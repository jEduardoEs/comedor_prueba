# Cadena de conexion de Postgres (Neon, Supabase o Vercel Postgres)
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"
# Para Neon/Supabase con pooling, Prisma necesita tambien la URL directa para migraciones:
DIRECT_URL="postgresql://usuario:password@host/db?sslmode=require"
# Clave secreta para firmar el JWT de sesion (genera una aleatoria larga)
JWT_SECRET="cambia-esto-por-una-clave-larga-y-aleatoria"
