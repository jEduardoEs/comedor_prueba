generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  CAJERO
  ADMIN
}

enum EstadoMesa {
  LIBRE
  OCUPADA
}

enum EstadoOrden {
  ABIERTA
  PAGADA
  CANCELADA
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
  AJUSTE
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  usuario      String   @unique
  passwordHash String
  rol          Rol      @default(CAJERO)
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  ordenes      Orden[]
  cuadres      CuadreCaja[]
}

model Mesa {
  id       String     @id @default(cuid())
  numero   Int        @unique
  estado   EstadoMesa @default(LIBRE)
  ordenes  Orden[]
}

model Categoria {
  id        String     @id @default(cuid())
  nombre    String     @unique
  orden     Int        @default(0)
  productos Producto[]
}

model Producto {
  id           String   @id @default(cuid())
  nombre       String
  descripcion  String?
  precio       Decimal  @db.Decimal(10, 2)
  activo       Boolean  @default(true)
  imagenUrl    String?
  categoriaId  String
  categoria    Categoria @relation(fields: [categoriaId], references: [id])
  creadoEn     DateTime @default(now())

  ordenItems         OrdenItem[]
  recetaInventario   RecetaInventario[]
}

model InventarioItem {
  id           String   @id @default(cuid())
  nombre       String
  unidad       String
  stockActual  Decimal  @db.Decimal(10, 2) @default(0)
  stockMinimo  Decimal  @db.Decimal(10, 2) @default(0)
  creadoEn     DateTime @default(now())

  recetaProductos   RecetaInventario[]
  movimientos       MovimientoInventario[]
}

// Receta: cuanto de cada insumo consume un producto al venderse (opcional, para descuento automatico de stock)
model RecetaInventario {
  id                String         @id @default(cuid())
  productoId        String
  producto          Producto       @relation(fields: [productoId], references: [id], onDelete: Cascade)
  inventarioItemId  String
  inventarioItem    InventarioItem @relation(fields: [inventarioItemId], references: [id], onDelete: Cascade)
  cantidadUsada     Decimal        @db.Decimal(10, 2)

  @@unique([productoId, inventarioItemId])
}

model MovimientoInventario {
  id                String                   @id @default(cuid())
  inventarioItemId  String
  inventarioItem    InventarioItem           @relation(fields: [inventarioItemId], references: [id])
  tipo              TipoMovimientoInventario
  cantidad          Decimal                  @db.Decimal(10, 2)
  motivo            String?
  fecha             DateTime                 @default(now())
}

model Orden {
  id         String      @id @default(cuid())
  mesaId     String
  mesa       Mesa        @relation(fields: [mesaId], references: [id])
  usuarioId  String
  usuario    Usuario     @relation(fields: [usuarioId], references: [id])
  estado     EstadoOrden @default(ABIERTA)
  total      Decimal     @db.Decimal(10, 2) @default(0)
  creadoEn   DateTime    @default(now())
  cerradoEn  DateTime?

  items      OrdenItem[]
  pago       Pago?
}

model OrdenItem {
  id              String   @id @default(cuid())
  ordenId         String
  orden           Orden    @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  productoId      String
  producto        Producto @relation(fields: [productoId], references: [id])
  cantidad        Int
  precioUnitario  Decimal  @db.Decimal(10, 2)
  notas           String?
}

model Pago {
  id          String     @id @default(cuid())
  ordenId     String     @unique
  orden       Orden      @relation(fields: [ordenId], references: [id])
  metodoPago  MetodoPago
  monto       Decimal    @db.Decimal(10, 2)
  fecha       DateTime   @default(now())
}

model CuadreCaja {
  id             String   @id @default(cuid())
  usuarioId      String
  usuario        Usuario  @relation(fields: [usuarioId], references: [id])
  fecha          DateTime @default(now())
  totalEfectivo  Decimal  @db.Decimal(10, 2) @default(0)
  totalTarjeta   Decimal  @db.Decimal(10, 2) @default(0)
  totalTransfer  Decimal  @db.Decimal(10, 2) @default(0)
  totalGeneral   Decimal  @db.Decimal(10, 2) @default(0)
  cerrado        Boolean  @default(false)
}
